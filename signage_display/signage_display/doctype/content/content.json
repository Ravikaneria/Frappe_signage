   "in_list_view": 1,
   "label": "Content Type",
   "options": "Image\nVideo\nYouTube\nWebpage\nURL Redirect\nPDF\nClock",
   "reqd": 1
  },
  {
   "fieldname": "sec_media",
   "fieldtype": "Section Break",
   "label": "Media / Source"
