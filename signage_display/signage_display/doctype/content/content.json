  },
  {
   "fieldname": "youtube_url",
   "fieldtype": "Data",
   "label": "YouTube URL",
   "depends_on": "eval:doc.content_type=='YouTube'",
   "description": "Paste any YouTube link: watch?v=, youtu.be/, or /shorts/"
  },
  {
   "fieldname": "youtube_embed_url",
   "fieldtype": "Data",
   "label": "YouTube Embed URL (auto-generated)",
   "read_only": 1,
   "depends_on": "eval:doc.content_type=='YouTube'"
  },
  {
   "fieldname": "webpage_url",
   "fieldtype": "Data",
   "label": "Webpage URL",
   "depends_on": "eval:doc.content_type=='Webpage'",
   "description": "Full URL of the webpage to embed fullscreen (must allow iframing)."
  },
  {
   "fieldname": "redirect_url",
   "fieldtype": "Data",
   "label": "URL",
   "depends_on": "eval:doc.content_type=='URL Redirect'",
   "description": "Any URL — displayed fullscreen as an iframe."
  },
  {
   "fieldname": "pdf_file",
   "fieldtype": "Attach",
   "label": "PDF File",
   "depends_on": "eval:doc.content_type=='PDF'",
   "description": "Upload a PDF. Each page becomes one slide. Max 50 pages."
  },
  {
   "fieldname": "pdf_pages_json",
   "fieldtype": "Long Text",
   "label": "PDF Pages (internal — do not edit)",
   "hidden": 1,
   "read_only": 1,
   "no_copy": 1
  },
  {
