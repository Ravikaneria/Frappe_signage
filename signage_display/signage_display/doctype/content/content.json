   "fieldtype": "Attach Image",
   "label": "Image",
   "depends_on": "eval:doc.content_type=='Image'"
  },
  {
   "fieldname": "video_file",
   "fieldtype": "Attach",
   "label": "Video File (MP4 / WebM)",
   "depends_on": "eval:doc.content_type=='Video'",
