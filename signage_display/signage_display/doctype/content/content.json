   "fieldname": "clock_format",
   "fieldtype": "Select",
   "label": "Clock Format",
   "options": "24 Hour\n12 Hour (AM/PM)",
   "depends_on": "eval:doc.content_type=='Clock'"
  },
  {
   "default": "1",
   "fieldname": "clock_show_date",
   "fieldtype": "Check",
   "label": "Show Date Below Clock",
   "depends_on": "eval:doc.content_type=='Clock'"
  },
  {
   "fieldname": "clock_timezone_label",
   "fieldtype": "Data",
   "label": "Label (optional)",
