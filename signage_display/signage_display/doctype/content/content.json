  {
   "fieldname": "youtube_embed_url",
   "fieldtype": "Data",
   "label": "YouTube Embed URL (auto-generated)",
   "read_only": 1,
   "depends_on": "eval:doc.content_type=='YouTube'"
  },
  {
   "fieldname": "webpage_url",
   "fieldtype": "Data",
   "label": "Webpage URL",
   "depends_on": "eval:doc.content_type=='Webpage'",
