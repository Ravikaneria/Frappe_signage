  },
  {
   "fieldname": "redirect_url",
   "fieldtype": "Data",
   "label": "URL",
   "depends_on": "eval:doc.content_type=='URL Redirect'",
   "description": "Any URL \u2014 displayed fullscreen as an iframe."
  },
  {
   "fieldname": "webpage_zoom",
   "fieldtype": "Float",
   "label": "Zoom Level (for TV)",
   "default": "1.3",
   "depends_on": "eval:doc.content_type=='Webpage' || doc.content_type=='URL Redirect'",
   "description": "1.0 = normal size, 1.3 = 30% larger (recommended for TV), 1.5 = 50% larger. Adjust if text looks too small or too large on your TV."
  },
  {
   "fieldname": "pdf_file",
   "fieldtype": "Attach",
   "label": "PDF File",
   "depends_on": "eval:doc.content_type=='PDF'",
   "description": "Upload a PDF. Each page becomes one slide. Max 50 pages."
  },
  {
   "fieldname": "pdf_pages_json",
   "fieldtype": "Long Text",
   "label": "PDF Pages (internal \u2014 do not edit)",
